# ============================================================
# MeetingMind — Environment Variables
# Copy this to .env and fill in your GCP values.
# NEVER commit .env to git.
# ============================================================

# ── GCP Core ──────────────────────────────────────────────
# Get from: gcloud config get-value project
PROJECT_ID=your-project-id

# Get from: gcloud projects describe $PROJECT_ID --format="value(projectNumber)"
PROJECT_NUMBER=your-project-number

# Region — must match where your Cloud SQL instance and Cloud Run service are
REGION=us-central1

# ── Service Account ───────────────────────────────────────
SA_NAME=meetingmind-sa
SERVICE_ACCOUNT=meetingmind-sa@your-project-id.iam.gserviceaccount.com

# ── AI Model ──────────────────────────────────────────────
MODEL=gemini-2.5-flash

# ── Cloud SQL PostgreSQL ──────────────────────────────────
# Get DB_HOST from: gcloud sql instances describe meetingmind-db --format="value(ipAddresses[0].ipAddress)"
DB_HOST=your-cloud-sql-public-ip
DB_NAME=meetingmind
DB_USER=meetingmind_user
DB_PASSWORD=your-strong-password-here
DB_PORT=5432

# ── Calendar ──────────────────────────────────────────────
# Use "primary" for the default calendar of the authenticated account
CALENDAR_ID=primary

# Timezone for date parsing (IANA format)
TIMEZONE=Asia/Kolkata

# ── Google Workspace MCP (Gmail, Docs, Drive) ─────────────
# Set to "true" to enable the Workspace MCP server
# Requires Domain-Wide Delegation configured in Google Workspace Admin
GOOGLE_WORKSPACE_ENABLED=false

# ── Setup Instructions ────────────────────────────────────
#
# First-time setup (run in order):
#
#   1. bash setup_gcp.sh          — creates Cloud SQL, service account, IAM roles
#   2. python init_db.py          — applies schema.sql (pgvector + all tables)
#   3. bash deploy.sh             — builds Dockerfile via Cloud Build, deploys to Cloud Run
#
# Re-deploy after code changes:
#   bash deploy.sh
#
# Fresh demo reset (wipe data + re-deploy):
#   bash fresh_start.sh
#
# Clear only tasks for a quick reset:
#   python clear_tasks.py --tasks
